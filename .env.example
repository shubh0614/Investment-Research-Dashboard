# ── Supabase ────────────────────────────────────────────────────────────────
# Obtained from `supabase start` (local) or the Supabase dashboard (hosted).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Server-only. Never expose to the browser. Used only for the onboarding
# transaction and seed scripts — never for ordinary tenant queries.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── LLM gateway (Phase 4) ────────────────────────────────────────────────────
# Provider: groq | openai | anthropic  (default: groq)
LLM_PROVIDER=groq
# Model string for the chosen provider (e.g. llama-3.1-70b-versatile for Groq)
LLM_MODEL=
# API key for the chosen provider
LLM_API_KEY=

# ── Embeddings (Phase 3) ─────────────────────────────────────────────────────
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=

# ── External data APIs (Phase 3) ─────────────────────────────────────────────
MARKET_DATA_API_KEY=
NEWS_API_KEY=

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
