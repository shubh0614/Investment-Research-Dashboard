# ── Supabase ────────────────────────────────────────────────────────────────
# Obtained from `supabase start` (local) or the Supabase dashboard (hosted).
# Local dev: http://127.0.0.1:54101   Hosted: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54101
# Use the JWT-format keys shown by `npx supabase status` (ANON_KEY field), NOT the
# sb_publishable_* key shown by `supabase start`. PostgREST requires the JWT format.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt-key-here
# Server-only. Never expose to the browser. Use the SERVICE_ROLE_KEY (JWT) from
# `npx supabase status`, NOT the sb_secret_* key from `supabase start`.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-key-here

# ── LLM gateway (Phase 4) ────────────────────────────────────────────────────
# Provider: groq | openai | anthropic  (default: groq)
LLM_PROVIDER=groq
# Model string for the chosen provider (e.g. llama-3.3-70b-versatile for Groq)
LLM_MODEL=
# API key for the chosen provider
LLM_API_KEY=

# ── Embeddings (Phase 3) ─────────────────────────────────────────────────────
# Used by `npm run seed` to embed KB documents and by the KB retriever at query time.
# Requires an OpenAI key - model is text-embedding-3-small (1536 dims, matches vector column).
# If unset, seed stores null vectors and the retriever falls back to keyword search.
OPENAI_API_KEY=

# ── External data APIs ───────────────────────────────────────────────────────
# Market data: Finnhub free tier (60 req/min).
# Register at https://finnhub.io - no credit card required.
# Price history is fetched from Yahoo Finance (no key needed).
# Demo tickers (NVDA, AMD, INTC, MSFT) are pre-warmed in query_cache by `npm run seed`,
# so the demo works without this key.
MARKET_DATA_API_KEY=

# Web search: Tavily API (free tier, 1000 req/month).
# Register at https://tavily.com - no credit card required.
# Used by the search_web tool in the AI agent pipeline.
TAVILY_API_KEY=

# News: NewsAPI.org developer plan (free, 100 req/day).
# Register at https://newsapi.org/register - no credit card.
# Demo news is pre-warmed in query_cache by `npm run seed`.
NEWS_API_KEY=

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
